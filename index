<!DOCTYPE html>
<html lang="ru">
<head> 
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Retail Banking IS</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --bg: #ffffff; --text: #1a1a1a; --accent: #0052ff; --gray: #f4f4f4; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 40px; }
        .container { max-width: 800px; margin: 0 auto; }
        h1 { font-weight: 600; letter-spacing: -1px; margin-bottom: 40px; }
        .service-card { border: 1px solid #e0e0e0; padding: 20px; border-radius: 8px; margin-bottom: 15px; transition: 0.2s; }
        .service-card:hover { border-color: var(--accent); }
        .btn { background: var(--accent); color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; font-size: 14px; }
        input { padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 250px; margin-right: 10px; }
        #status { margin-top: 20px; font-size: 14px; color: var(--accent); }
    </style>
</head>
<body>
    <div class="container">
        <h1>Проектирование ИС: Банковские услуги</h1>
        
        <div id="services-list">Загрузка доступных продуктов...</div>

        <hr style="margin: 40px 0; border: 0; border-top: 1px solid #eee;">

        <h3>Оставить заявку на консультацию</h3>
        <div class="form-group">
            <input type="text" id="clientName" placeholder="Ваше ФИО">
            <button class="btn" onclick="submitApplication()">Отправить запрос</button>
        </div>
        <div id="status"></div>
    </div>

    <script>
        // Инициализация Supabase
        const SUPABASE_URL = 'https://kskbewcuerghaapfcwoy.supabase.co/rest/v1/';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imtza2Jld2N1ZXJnaGFhcGZjd295Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg1NzM2MDUsImV4cCI6MjA5NDE0OTYwNX0.lkrqbqdOjwB6P-q_Ny_XtoquyuARBBY3MF6WY6O72-c';
        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        // Загрузка услуг
        async function loadServices() {
            const { data, error } = await supabase.from('services').select('*');
            if (error) return;
            
            const list = document.getElementById('services-list');
            list.innerHTML = data.map(s => `
                <div class="service-card">
                    <strong>${s.name}</strong> — ${s.interest_rate}%
                    <p style="font-size: 14px; color: #666; margin: 5px 0 0 0;">${s.description}</p>
                </div>
            `).join('');
        }

        // Отправка заявки
        async function submitApplication() {
            const name = document.getElementById('clientName').value;
            const statusEl = document.getElementById('status');
            
            if (!name) return alert('Введите имя');

            const { error } = await supabase
                .from('applications')
                .insert([{ client_name: name, service_id: 1 }]);

            if (error) {
                statusEl.innerText = 'Ошибка при отправке.';
            } else {
                statusEl.innerText = 'Заявка успешно зарегистрирована в системе.';
                document.getElementById('clientName').value = '';
            }
        }

        loadServices();
    </script>
</body>
</html>
